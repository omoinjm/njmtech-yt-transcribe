# .env.example - copy to .env and fill values

# Whisper model path (local path inside container or host when mounting)
WHISPER_MODEL_PATH="/whisper.cpp/models/ggml-base.en.bin"

# Vercel Blob uploader
VERCEL_BLOB_API_URL="https://api.blob.njmtech.co.za/api/v1/blob/upload"
VERCEL_BLOB_API_TOKEN="your-vercel-blob-api-token"

# Vercel sets PORT automatically for the Go API server. Set it locally only when running HTTP mode.
# PORT="3000"

# Required only when using -db mode
POSTGRES_URL="postgres://user:password@host/dbname?sslmode=require"

# Required when using docker-compose (used to resolve the image name)
DOCKERHUB_USERNAME="your-dockerhub-username"

# Infisical configuration (optional)
# Set INFISICAL_ENABLED to "true" to enable fetching secrets from Infisical.
INFISICAL_ENABLED=false
INFISICAL_PROJECT_ID="<infisical-project-id>"
INFISICAL_ENVIRONMENT="dev"
# Authentication for Infisical (choose one supported method). Example: Universal Auth
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID="<client-id>"
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET="<client-secret>"
INFISICAL_SITE_URL="https://app.infisical.com"

# Notes:
# - Keep secrets out of git. Use environment variables or your secret manager to inject these values.
# - If using Infisical, set INFISICAL_ENABLED=true and provide INFISICAL_PROJECT_ID and INFISICAL_ENVIRONMENT.
# - When building the Docker image locally or in CI, pass the build-arg INFISICAL_ENABLED=true to compile the provider (see Dockerfile).
